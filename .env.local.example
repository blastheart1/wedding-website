# ─────────────────────────────────────────────────────────────────────────────
# Luis & Bee Wedding — Environment Variables
#
# HOW TO GET THESE VALUES
# ────────────────────────
# Option A (recommended): Vercel + Neon integration
#   1. Deploy to Vercel first (vercel deploy)
#   2. In Vercel dashboard → Storage → Create Database → Neon
#   3. Run: vercel env pull .env.local
#   This auto-populates DATABASE_URL and all POSTGRES_* vars below.
#
# Option B: Manual Neon setup
#   1. Go to console.neon.tech → New Project
#   2. Copy the connection string into DATABASE_URL below
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (Neon via Vercel integration) ───────────────────────────────────
# If using `vercel env pull`, these are filled in automatically.
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Neon also exposes these (populated by `vercel env pull`):
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
PGHOST=
PGUSER=
PGDATABASE=
PGPASSWORD=

# ─── Admin Panel ──────────────────────────────────────────────────────────────
# Generate a bcrypt hash of your chosen password (cost factor 12):
#   node -e "const b=require('bcryptjs'); b.hash('YourPassword',12).then(console.log)"
# Then paste the output below.
ADMIN_PASSWORD_HASH=

# A random 32+ character secret for signing JWT session cookies:
#   openssl rand -hex 32
JWT_SECRET=

# ─── Cloudinary (image uploads / gallery) ─────────────────────────────────────
# 1. Sign up at https://cloudinary.com → Dashboard
# 2. Settings → API Keys: copy Cloud name, API Key, API Secret
# 3. Replace every placeholder below — the values here are a TEMPLATE only (not real).
#
# Template (replace with your real values):
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=abcdefghijklmnopqrstuvwxyz123456

# Must match CLOUDINARY_CLOUD_NAME — prefixed with NEXT_PUBLIC_ so the admin
# upload widget can build signed URLs in the browser:
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Your production domain — used for OpenGraph metadata.
# e.g. https://luisandbee.wedding  or  https://your-app.vercel.app
NEXT_PUBLIC_BASE_URL=
