# ─────────────────────────────────────────────────────────────────────────────
# Luis & Bee Wedding — Environment Variables
#
# HOW TO GET THESE VALUES
# ────────────────────────
# Option A (recommended): Vercel + Neon integration
#   1. Deploy to Vercel first (vercel deploy)
#   2. In Vercel dashboard → Storage → Create Database → Neon
#   3. Run: vercel env pull .env.local
#   This auto-populates DATABASE_URL and all POSTGRES_* vars below.
#
# Option B: Manual Neon setup
#   1. Go to console.neon.tech → New Project
#   2. Copy the connection string into DATABASE_URL below
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (Neon via Vercel integration) ───────────────────────────────────
# If using `vercel env pull`, these are filled in automatically.
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Neon also exposes these (populated by `vercel env pull`):
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
PGHOST=
PGUSER=
PGDATABASE=
PGPASSWORD=

# ─── Admin Panel ──────────────────────────────────────────────────────────────
# Choose a strong password (16+ chars). This is the only gate to /admin.
ADMIN_PASSWORD=

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Get these from: cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Same cloud name — safe to expose to the browser (used for upload URL):
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Your production domain — used for OpenGraph metadata.
# e.g. https://luisandbee.wedding  or  https://your-app.vercel.app
NEXT_PUBLIC_BASE_URL=
